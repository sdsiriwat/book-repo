{

  "compilerOptions": {
    // File Layout
    "rootDir": "./src",
    "outDir": "./dist",


    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "exclude": ["node_modules", "prisma.config.ts", "prisma/seed.ts"]

}
